{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["node_modules", "dist", ".claude", "*.md", "*.config.ts", "*.config.js", "routeTree.gen.ts"],
  "sortImports": {
    "groups": [
      "type",
      "builtin",
      "external",
      ["internal", "subpath"],
      ["parent", "sibling", "index"],
      "style",
      "unknown"
    ]
  },
  "sortTailwindcss": {},
  "sortPackageJson": {}
}
