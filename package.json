{
  "name": "whatevs",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "fmt": "turbo fmt",
    "fmt:check": "turbo fmt:check",
    "typecheck": "turbo typecheck",
    "check": "bun run fmt:check && turbo lint && turbo typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "turbo": "^2.8.17",
    "typescript": "catalog:"
  },
  "catalog": {
    "typescript": "^5.9.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6",
    "hono": "^4.12.9",
    "better-auth": "^1.5.6",
    "@tanstack/react-query": "^5.95.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/node": "^25.5.0",
    "@tailwindcss/vite": "^4.1.18",
    "vite": "^8.0.3",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxfmt",
      "oxlint --fix"
    ]
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
